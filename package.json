{
  "name": "web",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.5.0",
  "scripts": {
    "build": "vite-ssg build",
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "postinstall": "simple-git-hooks",
    "preview": "vite preview",
    "test": "vitest run --globals",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "@unhead/vue": "^3.1.3",
    "@vueuse/core": "^14.3.0",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@fontsource/nunito": "^5.2.7",
    "@fontsource/work-sans": "^5.2.8",
    "@gtm-support/vue-gtm": "^3.2.0",
    "@iconify/vue": "^5.0.1",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@rollup/pluginutils": "^5.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-link-attributes": "^3.0.5",
    "@types/node": "^24.13.1",
    "@unhead/schema-org": "^3.1.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.35",
    "@vue/server-renderer": "^3.5.35",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.4.1",
    "eslint-plugin-format": "^2.0.1",
    "gray-matter": "^4.0.3",
    "happy-dom": "^14.12.3",
    "lint-staged": "^17.0.7",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-prism": "^3.0.1",
    "prismjs": "^1.30.0",
    "rollup": "^4.61.1",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-markdown": "^32.0.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-layouts": "^0.11.0",
    "vite-ssg": "^28.3.0",
    "vite-ssg-sitemap": "^0.10.0",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4",
    "workbox-build": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ],
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm exec commitlint --edit $1",
    "pre-commit": "pnpm exec lint-staged --allow-empty"
  },
  "lint-staged": {
    "*": [
      "eslint --fix"
    ]
  },
  "eslintConfig": {
    "extends": [
      "@creasico/eslint-config/vue"
    ],
    "globals": {
      "vi": true,
      "vitest": true
    },
    "ignorePatterns": [
      "**/*.test.ts"
    ],
    "parserOptions": {
      "tsconfigRootDir": ".",
      "project": "./tsconfig.json"
    }
  }
}
